{
    "$schema": "https://raw.githubusercontent.com/ScoopInstaller/Scoop/master/schema.json",
    "version": "0.18.0",
    "description": "Aggregate and browse AI coding agent sessions (Claude Code, Codex, Gemini CLI, etc.) in one place. Desktop app, self-hosted server, or Docker",
    "homepage": "https://github.com/xintaofei/codeg",
    "license": "Apache-2.0",
    "depends": "main/nanazip",
    "architecture": {
        "64bit": {
            "url": "https://github.com/xintaofei/codeg/releases/download/v0.18.0/codeg_0.18.0_x64-setup.exe#/nsis.exe",
            "hash": "3d94e7f29587071bf14a37c47fd8cb525e5c1de8f1010ee680187ff3ca9a55d4"
        }
    },
    "installer": {
        "script": [
            "7z x -bso0 -bsp0 -y \"$dir\\nsis.exe\" \"-o$dir\"",
            "Remove-Item -Path \"$dir\\nsis.exe\" -Recurse",
            "Remove-Item -Path \"$dir\\*.nsi\" -Recurse",
            "Remove-Item -Path \"$dir\\`$*\" -Recurse"
        ]
    },
    "shortcuts": [
        [
            "codeg.exe",
            "Codeg"
        ]
    ],
    "bin": [
        "codeg.exe",
        "codeg-server.exe",
        "codeg-mcp.exe"
    ],
    "checkver": "github",
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/xintaofei/codeg/releases/download/v$version/codeg_$version_x64-setup.exe#/nsis.exe"
            }
        }
    }
}
