{
    "$schema": "https://raw.githubusercontent.com/ScoopInstaller/Scoop/master/schema.json",
    "version": "0.14.6",
    "description": "Aggregate and browse AI coding agent sessions (Claude Code, Codex, Gemini CLI, etc.) in one place. Desktop app, self-hosted server, or Docker",
    "homepage": "https://github.com/xintaofei/codeg",
    "license": "Apache-2.0",
    "depends": "main/nanazip",
    "architecture": {
        "64bit": {
            "url": "https://github.com/xintaofei/codeg/releases/download/v0.14.2/codeg_0.14.2_x64-setup.exe#/nsis.exe",
            "hash": "1d45286c3add00082abd88a585dca828ed02da8c0930242c6adcb524e94226f2"
        }
    },
    "installer": {
        "script": [
            "7z x -y \"$dir\\nsis.exe\" \"-o$dir\"",
            "Remove-Item -Path \"$dir\\nsis.exe\" -Recurse",
            "Remove-Item -Path \"$dir\\*.nsi\" -Recurse",
            "Remove-Item -Path \"$dir\\`$*\" -Recurse"
        ]
    },
    "shortcuts": [
        [
            "codeg.exe",
            "Codeg"
        ]
    ],
    "bin": [
        "codeg.exe",
        "codeg-server.exe",
        "codeg-mcp.exe"
    ],
    "checkver": "github",
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/xintaofei/codeg/releases/download/v0.14.2/codeg_0.14.2_x64-setup.exe#/nsis.exe"
            }
        }
    }
}
