{
    "$schema": "https://raw.githubusercontent.com/ScoopInstaller/Scoop/master/schema.json",
    "version": "2.0.3",
    "description": "Process-level transparent proxy — Hook Winsock API via DLL injection to transparently forward all network traffic from a target process through an HTTP proxy. No route table changes, no routing rules",
    "homepage": "https://github.com/gdm257/ghost-proxifier",
    "license": "MIT",
    "architecture": {
        "64bit": {
            "url": "https://github.com/gdm257/ghost-proxifier/releases/download/2.0.3/ghost-proxifier-amd64.zip",
            "hash": "sha256:14eaf41d21493a0e24f85ddb669b821e705134301f7b6d49e98d14a238f80ef8"
        }
    },
    "pre_install": [
        "if (!(Test-Path \"$persist_dir\\config.json\")) { New-Item -ItemType Directory -Path $persist_dir -Force | Out-Null; [System.IO.File]::WriteAllText(\"$persist_dir\\config.json\", '{}') }"
    ],
    "bin": "ghost-proxifier.exe",
    "persist": ["config.json"],
    "checkver": "github",
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/gdm257/ghost-proxifier/releases/download/$version/ghost-proxifier-amd64.zip"
            }
        }
    }
}
