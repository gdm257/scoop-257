{
    "$schema": "https://raw.githubusercontent.com/ScoopInstaller/Scoop/master/schema.json",
    "version": "v3.0.0+1",
    "description": "Windows & Linux system tray app for automatic time tracking and metrics generated from your Figma, Postman, etc. usage",
    "homepage": "https://wakatime.com",
    "license": "BSD-3-Clause",
    "architecture": {
        "64bit": {
            "url": "https://github.com/wakatime/desktop-wakatime/releases/download/v3.0.0%2B1/wakatime-win32-x64.exe#/nsis.exe",
            "hash": "sha256:de91fffe387eecae0dfa28705470c20cccd538ea1c530b2bc111309e2a64cdb5"
        },
        "32bit": {
            "url": "https://github.com/wakatime/desktop-wakatime/releases/download/v3.0.0%2B1/wakatime-win32.exe#/nsis.exe",
            "hash": "sha256:67fe85d5e5a61fa9aff70a03cb2415285d6e1370c6c1035dc6ff97dbd74eebc4"
        },
        "arm64": {
            "url": "https://github.com/wakatime/desktop-wakatime/releases/download/v3.0.0%2B1/wakatime-win32-arm64.exe#/nsis.exe",
            "hash": "sha256:884418eacf4a77906ef4bb92c87810ef0a2d9f2a0aa7062ee4d930eae224792c"
        }
    },
    "installer": {
        "script": [
            "7z x -bso0 -bsp0 -y \"$dir\\nsis.exe\" \"-o$dir\" ",
            "Expand-7zipArchive \"$dir\\`$PLUGINSDIR\\app-64.7z\" \"$dir\"",
            "Remove-Item -Path \"$dir\\nsis.exe\" -Recurse",
            "Remove-Item -Path \"$dir\\*.nsi\" -Recurse",
            "Remove-Item -Path \"$dir\\`$*\" -Recurse"
        ]
    },
    "shortcuts": [["wakatime.exe", "WakaTime"]],
    "checkver": {
        "github": "https://github.com/wakatime/desktop-wakatime"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/wakatime/desktop-wakatime/releases/download/$version/wakatime-win32-x64.exe#/nsis.exe"
            },
            "32bit": {
                "url": "https://github.com/wakatime/desktop-wakatime/releases/download/$version/wakatime-win32.exe#/nsis.exe"
            },
            "arm64": {
                "url": "https://github.com/wakatime/desktop-wakatime/releases/download/$version/wakatime-win32-arm64.exe#/nsis.exe"
            }
        }
    }
}
