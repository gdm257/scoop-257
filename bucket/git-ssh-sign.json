{
    "$schema": "https://raw.githubusercontent.com/ScoopInstaller/Scoop/master/schema.json",
    "version": "1.1.0",
    "description": "A script to use ssh-agent(ssh-add) keys for git commit",
    "homepage": "https://github.com/gdm257/scoop-257",
    "license": "Unlicense",
    "notes": [
        "To setup SSH commit signing, run:",
        "",
        "  1. Enable ssh-agent service:",
        "       Get-Service ssh-agent | Set-Service -StartupType Automatic",
        "       Start-Service ssh-agent",
        "",
        "  2. Load your signing key into ssh-agent:",
        "       ssh-add ~/.ssh/id_ed25519",
        "       # Verify: ssh-add -l",
        "",
        "  3. (Optional) Set SSH_AUTH_SOCK (add to PowerShell profile):",
        "       $env:SSH_AUTH_SOCK = '\\\\.\\pipe\\openssh-ssh-agent'",
        "",
        "  4. Configure git commit signing:",
        "       git config --global commit.gpgsign true",
        "       git config --global gpg.format ssh",
        "       git config --global gpg.ssh.program git-ssh-sign",
        "       git config --global gpg.push.gpgsign false",
        "       git config --global gpg.ssh.allowedSignersFile ~/.ssh/allowed_signers",
        "",
        "  5. Create ~/.ssh/allowed_signers (one line per key):",
        "       # Format: principals options keytype base64-key",
        "       alice ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAI...",
        "       bob,email=bob@example.com ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAI..."
    ],
    "depends": ["main/openssh"],
    "url": [
        "https://raw.githubusercontent.com/gdm257/scoop-257/refs/heads/master/LICENSE"
    ],
    "installer": {
        "script": [
            "[System.IO.File]::WriteAllText(\"$dir\\git-ssh-sign\", '#!/bin/sh\nexec \"$(scoop prefix openssh)/ssh-keygen.exe\" -U \"$@\"')"
        ]
    },
    "bin": ["git-ssh-sign"],
    "checkver": "github",
    "autoupdate": {
        "url": [
            "https://raw.githubusercontent.com/gdm257/scoop-257/refs/heads/master/LICENSE"
        ]
    }
}
