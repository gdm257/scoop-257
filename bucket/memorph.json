            "Remove-Item -Path \"$dir\\`$*\" -Recurse"
        ]
    },
    "bin": "memorph.exe",
    "shortcuts": [["memorph-tauri.exe", "Memorph"]],
    "checkver": "github",
    "autoupdate": {
        "architecture": {
            "64bit": {
