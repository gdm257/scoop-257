{
    "$schema": "https://raw.githubusercontent.com/ScoopInstaller/Scoop/master/schema.json",
    "version": "1.0.0",
    "description": "PATH",
    "homepage": "https://github.com/gdm257/scoop-257",
    "license": "Unlicense",
    "depends": ["main/git"],
    "url": ["https://unlicense.org/UNLICENSE"],
    "installer": {
        "script": [
            "Add-Path \"$(appsdir)\\git\\current\\usr\\bin\" -Global:$global"
        ]
    },
    "uninstaller": {
        "script": [
            "Remove-Path \"$(appsdir)\\git\\current\\usr\\bin\" -Global:$global"
        ]
    }
}
