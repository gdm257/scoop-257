{
    "$schema": "https://raw.githubusercontent.com/ScoopInstaller/Scoop/master/schema.json",
    "version": "1.0.0",
    "description": "command shims",
    "homepage": "https://github.com/gdm257/scoop-257",
    "license": "Unlicense",
    "depends": ["main/ugrep"],
    "url": ["https://unlicense.org/UNLICENSE"],
    "installer": {
        "script": "Copy-Item -Path (Join-Path $bucketsdir $bucket 'scripts\\command-wrap.ps1') -Destination (Join-Path $dir 'command-wrap.ps1') -Force"
    },
    "bin": [
        ["command-wrap.ps1", "grep", "ugrep,egrep.exe"],
        ["command-wrap.ps1", "egrep", "ugrep,egrep.exe"]
    ]
}
