{
    "$schema": "https://raw.githubusercontent.com/ScoopInstaller/Scoop/master/schema.json",
    "version": "latest",
    "homepage": "http://www.tasofro.net/mdk/",
    "description": "Grief Syndrome is a doujin game by Twilight Frontier (also known as Tasofro) which was released at Comiket 80 on August 13, 2011. It is a side-scrolling beat-em-up featuring the characters of Puella Magi Madoka Magica",
    "license": "Freeware",
    "url": [
        "https://github.com/Zarmiv-01/Grief-Syndrome-Project/archive/refs/heads/main.zip"
    ],
    "extract_dir": "Grief-Syndrome-Project-main",
    "installer": {
        "script": [
            "Rename-Item -Path \"$dir\\Grief Syndrome [Main Game]\" \"main-game\"",
            "7z x \"$dir\\main-game\\gs00.zip\" \"-o$dir/main-game\""
        ]
    },
    "shortcuts": [
        ["main-game/griefsyndrome.exe", "GriefSyndrome"],
        [
            "main-game/ConfigTool.exe",
            "GriefSyndrome ConfigTool"
        ],
        [
            "main-game/griefsyndrome_online.exe",
            "GriefSyndromeOnline"
        ]
    ],
    "persist": ["save", "gso.ini"]
}
