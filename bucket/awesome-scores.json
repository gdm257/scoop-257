{
    "$schema": "https://raw.githubusercontent.com/ScoopInstaller/Scoop/master/schema.json",
    "version": "latest",
    "description": "awesome scores",
    "homepage": "https://github.com/gdm257/awesome-scores",
    "license": "Unknown",
    "url": "https://www.apache.org/licenses/LICENSE-2.0.txt",
    "installer": {
        "script": [
            "if (!(Test-Path \"$persist_dir/data\")) { New-Item -ItemType Directory -Path \"$persist_dir/data\" }",
            "if (!(Test-Path \"$persist_dir/data/awesome-scores\")) { git clone --depth 1 https://github.com/gdm257/awesome-scores \"$persist_dir/data/awesome-scores\" }",
            "if (!(Test-Path \"$persist_dir/data/touhou-midi-collection\")) { git clone --depth 1 https://github.com/AyHa1810/touhou-midi-collection \"$persist_dir/data/touhou-midi-collection\" }",
            "if (!(Test-Path \"$persist_dir/data/lilymusic\")) { git clone --depth 1 https://github.com/wbsoft/lilymusic \"$persist_dir/data/lilymusic\" }",
            "if (!(Test-Path \"$persist_dir/data/Lilypond-Sheet-Music\")) { git clone --depth 1 https://github.com/cellist/Lilypond-Sheet-Music \"$persist_dir/data/Lilypond-Sheet-Music\" }",
            "if (!(Test-Path \"$persist_dir/data/music\")) { git clone --depth 1 https://github.com/noteflakes/music \"$persist_dir/data/music\" }",
            "if (!(Test-Path \"$persist_dir/data/nenuvar\")) { git clone --depth 1 https://github.com/nsceaux/nenuvar \"$persist_dir/data/nenuvar\" }"
        ]
    },
    "persist": "data"
}
